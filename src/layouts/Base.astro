---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { locales, defaultLang } from '../i18n/utils';

const {
  lang = 'en',
  path = Astro.url.pathname,
  title = 'BoB · Own your AI. BoB does the rest.',
  description = 'BoB turns a plain-English idea into finished, checked work. Local-first, no subscription, no lock-in. A Canopy Seed project.',
  ogDescription = description,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/icon/bob-crest-64.png" />
    <link rel="apple-touch-icon" href="/icon/bob-crest-256.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content="/brand/bob-crest.png" />
    <meta name="theme-color" content="#0a120e" />
    <link rel="canonical" href={getAbsoluteLocaleUrl(lang, path)} />
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={getAbsoluteLocaleUrl(l, path)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl(defaultLang, path)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {lang === 'zh-Hans' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    )}
    {lang === 'ja' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    )}
  </head>
  <body>
    <Nav locale={lang} path={path} />
    <slot />
    <Footer locale={lang} path={path} />
  </body>
</html>
