---
import { GITHUB, RELEASES } from '../consts';
import { useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const { locale = 'en', path = '/' } = Astro.props;
const t = useTranslations(locale);
let base = getRelativeLocaleUrl(locale, '/');
if (!base.endsWith('/')) base += '/';
const knHref = getRelativeLocaleUrl(locale, '/knowledge');
---
<footer class="footer">
  <div class="footer-brand">
    <span class="brand-badge"><img src="/icon/bob-crest-inv-gray.png" alt="" width="44" height="44" /></span>
    <div>
      <p class="brand-name">BoB</p>
      <p class="footer-by">{t('footer.by')}</p>
    </div>
  </div>
  <nav class="footer-links">
    <a href={GITHUB} target="_blank" rel="noopener">{t('footer.github')}</a>
    <a href={RELEASES} target="_blank" rel="noopener">{t('footer.download')}</a>
    <a href={`${base}#how`}>{t('footer.how')}</a>
    <a href={`${base}#story`}>{t('footer.story')}</a>
    <a href={knHref}>{t('footer.knowledge')}</a>
  </nav>
  <p class="footer-fine">{t('footer.fine')}<br />{t('footer.copyright')}</p>
</footer>
