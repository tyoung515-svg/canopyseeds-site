---
import { GITHUB, RELEASES } from '../consts';
import { useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';
import LangSwitcher from './LangSwitcher.astro';

const { locale = 'en', path = '/' } = Astro.props;
const t = useTranslations(locale);
let base = getRelativeLocaleUrl(locale, '/');
if (!base.endsWith('/')) base += '/';
const knHref = getRelativeLocaleUrl(locale, '/knowledge');
---
<header class="nav">
  <a class="brand" href={base}>
    <span class="brand-badge"><img src="/icon/bob-crest-inv-gray.png" alt="" width="42" height="42" /></span>
    <span class="brand-name">BoB</span>
    <span class="brand-by">{t('nav.brandBy')}</span>
  </a>
  <nav class="nav-links">
    <a href={`${base}#how`}>{t('nav.how')}</a>
    <a href={`${base}#why`}>{t('nav.why')}</a>
    <a href={knHref}>{t('nav.knowledge')}</a>
    <a href={GITHUB} target="_blank" rel="noopener">{t('nav.github')}</a>
    <LangSwitcher locale={locale} path={path} />
    <a class="btn btn-sm" href={RELEASES} target="_blank" rel="noopener">{t('nav.getBob')}</a>
  </nav>
</header>
