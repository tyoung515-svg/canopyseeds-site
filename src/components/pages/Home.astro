---
import Base from '../../layouts/Base.astro';
import { GITHUB, RELEASES } from '../../consts';
import { useTranslations } from '../../i18n/utils';

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
---

<Base
  lang={locale}
  path="/"
  title={t('meta.home.title')}
  description={t('meta.home.description')}
  ogDescription={t('meta.home.ogDescription')}
>
    <main>
      <!-- hero -->
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">{t('home.hero.eyebrow')}</p>
          <h1>{t('home.hero.titleLine1')}<br />{t('home.hero.titleLine2')}</h1>
          <p class="lede" set:html={t('home.hero.lede')}></p>
          <div class="cta-row">
            <a class="btn btn-lg" href={RELEASES} target="_blank" rel="noopener">{t('home.hero.ctaPrimary')}</a>
            <a class="btn btn-ghost btn-lg" href="#how">{t('home.hero.ctaSecondary')}</a>
          </div>
          <p class="trust">{t('home.hero.trust')}</p>
        </div>
        <div class="hero-art">
          <img
            src="/brand/bob-sticker.png"
            alt={t('home.hero.artAlt')}
            width="520"
            loading="eager"
          />
        </div>
      </section>

      <!-- what the name means -->
      <section class="backronym">
        <div class="backronym-inner">
          <p class="eyebrow">{t('home.backronym.eyebrow')}</p>
          <h2>{t('home.backronym.heading')}</h2>
          <div class="bob-letters">
            <div class="bob-letter">
              <h3><span class="bob-cap">B</span>uild</h3>
              <p>{t('home.backronym.buildBody')}</p>
            </div>
            <div class="bob-letter">
              <h3><span class="bob-cap">O</span>rchestrate</h3>
              <p>{t('home.backronym.orchestrateBody')}</p>
            </div>
            <div class="bob-letter">
              <h3><span class="bob-cap">B</span>ind</h3>
              <p>{t('home.backronym.bindBody')}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- the moment -->
      <section class="band">
        <div class="band-inner">
          <h2>{t('home.moment.heading')}</h2>
          <p>{t('home.moment.body')}</p>
          <p class="strong">{t('home.moment.strong')}</p>
          <p class="pull">{t('home.moment.pull')}</p>
        </div>
      </section>

      <!-- what BoB is -->
      <section id="why" class="section">
        <div class="section-head">
          <h2>{t('home.why.heading')}</h2>
          <p>{t('home.why.intro')}</p>
        </div>
        <div class="cards">
          <div class="card">
            <div class="card-ic">✓</div>
            <h3>{t('home.why.card1Title')}</h3>
            <p set:html={t('home.why.card1Body')}></p>
          </div>
          <div class="card">
            <div class="card-ic">⚒</div>
            <h3>{t('home.why.card2Title')}</h3>
            <p>{t('home.why.card2Body')}</p>
          </div>
          <div class="card">
            <div class="card-ic">⛰</div>
            <h3>{t('home.why.card3Title')}</h3>
            <p>{t('home.why.card3Body')}</p>
          </div>
        </div>
      </section>

      <!-- who it's for -->
      <section id="who" class="section">
        <div class="section-head">
          <h2>{t('home.who.heading')}</h2>
          <p>{t('home.who.intro')}</p>
        </div>
        <div class="use-cases">
          <div class="card">
            <div class="card-ic">❯_</div>
            <h3>{t('home.who.devTitle')}</h3>
            <p>{t('home.who.devBody')}</p>
          </div>
          <div class="card">
            <div class="card-ic">✦</div>
            <h3>{t('home.who.kwTitle')}</h3>
            <p>{t('home.who.kwBody')}</p>
          </div>
          <div class="card">
            <div class="card-ic">▦</div>
            <h3>{t('home.who.bizTitle')}</h3>
            <p>{t('home.who.bizBody')}</p>
          </div>
          <div class="card">
            <div class="card-ic">✎</div>
            <h3>{t('home.who.writerTitle')}</h3>
            <p>{t('home.who.writerBody')}</p>
          </div>
        </div>
        <p class="section-note">{t('home.who.note')}</p>
      </section>

      <!-- how it works -->
      <section id="how" class="section section-alt">
        <div class="section-head">
          <h2>{t('home.how.heading')}</h2>
          <p>{t('home.how.intro')}</p>
        </div>
        <ol class="steps">
          <li>
            <span class="step-n">1</span>
            <div>
              <h3>{t('home.how.step1Title')}</h3>
              <p>{t('home.how.step1Body')}</p>
            </div>
          </li>
          <li>
            <span class="step-n">2</span>
            <div>
              <h3>{t('home.how.step2Title')}</h3>
              <p>{t('home.how.step2Body')}</p>
            </div>
          </li>
          <li>
            <span class="step-n">3</span>
            <div>
              <h3>{t('home.how.step3Title')}</h3>
              <p>{t('home.how.step3Body')}</p>
            </div>
          </li>
          <li>
            <span class="step-n">4</span>
            <div>
              <h3>{t('home.how.step4Title')}</h3>
              <p>{t('home.how.step4Body')}</p>
            </div>
          </li>
        </ol>
      </section>

      <!-- idea to reality depth: council + memory -->
      <section class="section">
        <div class="section-head">
          <h2>{t('home.council.heading')}</h2>
          <p set:html={t('home.council.intro')}></p>
        </div>
        <div class="features">
          <div class="card">
            <div class="card-ic">⚖</div>
            <h3>{t('home.council.councilTitle')}</h3>
            <p set:html={t('home.council.councilBody')}></p>
          </div>
          <div class="card">
            <div class="card-ic">❖</div>
            <h3>{t('home.council.memoryTitle')}</h3>
            <p set:html={t('home.council.memoryBody')}></p>
          </div>
        </div>
      </section>

      <!-- interoperability -->
      <section id="open" class="section section-alt">
        <div class="section-head">
          <h2>{t('home.interop.heading')}</h2>
          <p>{t('home.interop.intro')}</p>
        </div>
        <div class="features">
          <div class="card">
            <div class="card-ic">⇄</div>
            <h3>{t('home.interop.driveTitle')}</h3>
            <p>{t('home.interop.driveBody')}</p>
          </div>
          <div class="card">
            <div class="card-ic">▣</div>
            <h3>{t('home.interop.buildInTitle')}</h3>
            <p>{t('home.interop.buildInBody')}</p>
          </div>
        </div>
      </section>

      <!-- proof / the builder -->
      <section id="story" class="section">
        <div class="section-head">
          <h2>{t('home.proof.heading')}</h2>
          <p set:html={t('home.proof.body')}></p>
        </div>

        <div class="stats">
          <div><span class="stat-n">789</span><span class="stat-l">{t('home.proof.stat1Label')}</span></div>
          <div><span class="stat-n">4</span><span class="stat-l">{t('home.proof.stat2Label')}</span></div>
          <div><span class="stat-n">0</span><span class="stat-l">{t('home.proof.stat3Label')}</span></div>
        </div>

        <div class="builder">
          <p set:html={t('home.proof.builder')}></p>
          <p class="builder-kicker" set:html={t('home.proof.kicker')}></p>
        </div>
      </section>

      <!-- philosophy -->
      <section class="band band-green">
        <div class="band-inner">
          <p class="eyebrow eyebrow-light">{t('home.philosophy.eyebrow')}</p>
          <h2>{t('home.philosophy.heading')}</h2>
          <p>{t('home.philosophy.body')}</p>
          <p class="strong">{t('home.philosophy.strong')}</p>
        </div>
      </section>

      <!-- get BoB -->
      <section id="get" class="section get">
        <img src="/icon/bob-crest-inv-gray.png" alt={t('home.cta.artAlt')} class="get-art" width="150" loading="lazy" />
        <h2>{t('home.cta.heading')}</h2>
        <p>{t('home.cta.body')}</p>
        <div class="cta-row cta-center">
          <a class="btn btn-lg" href={RELEASES} target="_blank" rel="noopener">{t('home.cta.primary')}</a>
          <a class="btn btn-ghost btn-lg" href={GITHUB} target="_blank" rel="noopener">{t('home.cta.secondary')}</a>
        </div>
      </section>
    </main>
</Base>
