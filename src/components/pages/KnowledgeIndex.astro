---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { useTranslations, localeOf, slugOf, pickEntry, defaultLang } from '../../i18n/utils';

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('knowledge', (e) => !e.data.draft);
// English catalogue is the canonical, ordered set of slugs.
const englishEntries = all
  .filter((e) => localeOf(e) === defaultLang)
  .sort(
    (a, b) =>
      (a.data.order ?? 100) - (b.data.order ?? 100) ||
      slugOf(a).localeCompare(slugOf(b)),
  );
// Show a localized entry where one exists, else fall back to English.
const entries = englishEntries.map((e) => pickEntry(all, locale, slugOf(e)) ?? e);
const categories = ['Papers', 'Tutorials', 'Work Shapes', 'Architecture'];
---

<Base lang={locale} path="/knowledge/" title={t('meta.knowledge.title')} description={t('meta.knowledge.description')}>
  <div class="kn-wrap">
    <div class="kn-head">
      <p class="eyebrow">{t('knowledge.eyebrow')}</p>
      <h1>{t('knowledge.title')}</h1>
      <p>{t('knowledge.intro')}</p>
    </div>

    <div class="kn-filters" id="filters">
      <button class="kn-filter" data-filter="all" aria-pressed="true">{t('knowledge.filterAll')}</button>
      {
        categories.map((c) => (
          <button class="kn-filter" data-filter={c} aria-pressed="false">
            {t(`knowledge.category.${c}`)}
          </button>
        ))
      }
    </div>

    <div class="kn-grid" id="grid">
      {
        entries.map((e) => (
          <a class="kn-card" href={`/knowledge/${slugOf(e)}/`} data-cat={e.data.category} data-fmt={e.data.format}>
            <div class="kn-tags">
              <span class="kn-badge cat">{t(`knowledge.category.${e.data.category}`)}</span>
              <span class="kn-badge fmt">{t(`knowledge.format.${e.data.format}`)}</span>
            </div>
            <h3>{e.data.title}</h3>
            <p>{e.data.description}</p>
            <span class="kn-more">{t('knowledge.read')}</span>
          </a>
        ))
      }
    </div>
    <p class="kn-empty" id="empty" style="display:none">{t('knowledge.moreSoon')}</p>
  </div>

  <script>
    const btns = document.querySelectorAll<HTMLButtonElement>('.kn-filter');
    const cards = document.querySelectorAll<HTMLElement>('.kn-card');
    const empty = document.getElementById('empty');
    btns.forEach((b) =>
      b.addEventListener('click', () => {
        const f = b.dataset.filter;
        btns.forEach((x) => x.setAttribute('aria-pressed', String(x === b)));
        let shown = 0;
        cards.forEach((c) => {
          const match = f === 'all' || c.dataset.cat === f;
          c.style.display = match ? '' : 'none';
          if (match) shown++;
        });
        if (empty) empty.style.display = shown ? 'none' : '';
      }),
    );
  </script>
</Base>
