---
import KnowledgeEntry from '../../components/pages/KnowledgeEntry.astro';
import { getCollection } from 'astro:content';
import { localeOf, slugOf } from '../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('knowledge');
  return all
    .filter((e) => localeOf(e) === 'en')
    .map((e) => ({ params: { slug: slugOf(e) }, props: { entry: e, locale: 'en' } }));
}

const { entry, locale } = Astro.props;
---
<KnowledgeEntry entry={entry} locale={locale} />
